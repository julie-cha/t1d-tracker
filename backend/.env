NODE_ENV=development
PORT=5000

# Google Cloud SQL - Development (using Cloud SQL Proxy)
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/diabetes_care_db

# Google Cloud SQL - Production (Direct connection)
# DATABASE_URL=postgresql://postgres:your-password@/diabetes_care_db?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME

# Google Cloud Settings
GCP_PROJECT_ID=your-project-id
GCP_SQL_INSTANCE=your-instance-name
GCP_REGION=us-east1

# JWT
JWT_SECRET=your-secret-key-here-change-this-in-production
JWT_EXPIRE=7d

# CORS
CLIENT_URL=http://localhost:8081