NODE_ENV=production
PORT=8080

# Google Cloud SQL - Production
GCP_PROJECT_ID=your-project-id
GCP_SQL_INSTANCE=diabetes-care-db
GCP_REGION=us-east1
DB_PASSWORD=your-strong-password

# JWT
JWT_SECRET=generate-a-strong-secret-key-for-production
JWT_EXPIRE=7d

# CORS - Update with your production domain
CLIENT_URL=https://your-app-domain.com